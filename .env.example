# Server Configuration
SERVER_LOG_LEVEL=info
SERVER_HEALTH_PORT=8081
SERVER_API_PORT=8080

# TimescaleDB Configuration
PSQL_DSN=postgres://postgres:postgres@localhost:5437/telemetry?sslmode=disable
PSQL_BATCH_SIZE=1000
PSQL_FLUSH_INTERVAL=1s
PSQL_MAX_CONNECTIONS=25
PSQL_MAX_IDLE_CONNS=5

# RabbitMQ Configuration (Multi-tenant mode)
AMQP_BROKER_URL=amqp://admin:password@rabbitmq:5672/
AMQP_CONSUMER_TAG=telemetry-service
AMQP_PREFETCH_COUNT=100
AMQP_AUTO_ACK=false
AMQP_ALLOWED_VHOSTS=
AMQP_RECONNECT_DELAY=5s
